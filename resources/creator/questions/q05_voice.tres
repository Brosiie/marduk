[ext_resource type="Script" path="res://scripts/player/creator_choice.gd" id="1_choice"]

[sub_resource type="Resource" id="c_v0"]
script = ExtResource("1_choice")
choice_id = &"voice_measured"
text = "Measured. I think before I speak. Most of the time."
sets_voice_pack = 0

[sub_resource type="Resource" id="c_v1"]
script = ExtResource("1_choice")
choice_id = &"voice_clipped"
text = "Clipped. I waste no syllables."
sets_voice_pack = 1

[sub_resource type="Resource" id="c_v2"]
script = ExtResource("1_choice")
choice_id = &"voice_warm"
text = "Warm. The kind of voice that can sing if it wants to."
sets_voice_pack = 2

[sub_resource type="Resource" id="c_v3"]
script = ExtResource("1_choice")
choice_id = &"voice_low"
text = "Low. Carries through walls. People stop listening when I start."
sets_voice_pack = 3

