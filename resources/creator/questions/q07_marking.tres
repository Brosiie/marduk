race_filter = &"anunnaki"

[sub_resource type="Resource" id="c_an_calligraphy"]
script = ExtResource("1_choice")
choice_id = &"mark_an_calligraphy"
text = "Calligraphy tattoos along the forearm. The first poem you memorized."
