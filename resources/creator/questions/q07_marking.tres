[gd_resource type="CreatorQuestion" load_steps=22 format=3]

[ext_resource type="Script" path="res://scripts/player/creator_choice.gd" id="1_choice"]

; ── Anunnaki-Blooded markings ───────────────────────────────────────
[sub_resource type="Resource" id="c_an_kohl"]
script = ExtResource("1_choice")
choice_id = &"mark_an_kohl"
text = "Kohl-lined eyes. The court script around the lid."
sets_cultural_marking = 1
race_filter = &"anunnaki"

[sub_resource type="Resource" id="c_an_bindi"]
script = ExtResource("1_choice")
choice_id = &"mark_an_bindi"
text = "Gold bindi at the brow. Thin script down the temple."
