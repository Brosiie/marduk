; Iron Crown Outskirts. The road from Ashurim to Babilim.
; "Caravan brigands, escaped temple-slaves, the occasional minor demon that
; slipped through a thinning seal." -- world_map.gd
;
; Layout (north -> south, Babilim at north, Ashurim at south):
;   z=-90  Babilim warp + watchtower + lvl 10-12 mob spawn (demons + temple-marked)
;   z=-60  patrol tower
;   z=-30  patrol tower + lvl 8-9 mob spawn (mixed)
;   z=  0  patrol tower + Reed Wastes side-warp (east) + Lodestone
;   z=+30  patrol tower + lvl 7-8 mob spawn (brigands + temple-marked)
;   z=+60  patrol tower
;   z=+90  Ashurim warp + watchtower + PlayerSpawn + lvl 6-7 mob spawn (brigands only)
;
; Geographic difficulty gradient: weakest mobs at the Ashurim border (south),
; strongest near Babilim (north). Walking the road north is the difficulty
; curve.
;
; Atmosphere: dust-gold sky, distant Babilim torchlight glowing on the
; northern horizon, drifting trail-dust, single warm directional from
; behind the city (so silhouettes face the player as they ride north).

[sub_resource type="Environment" id="Env_ico"]
background_mode = 1
background_color = Color(0.4800, 0.4000, 0.3000, 1)
ambient_light_source = 2
ambient_light_color = Color(0.5500, 0.4600, 0.3800, 1)
