; The Seventh Master is NOT placed here directly. NPCRoster spawns him
; at Vector3(0, 1.0, 0) on scene load, gated by seventh_breath_pilgrimage_done.
; This keeps the scene's NPC roster declarative and central rather than
; embedding visibility-gated nodes into the .tscn.

[node name="LoreRune_the_seventh_unspoken" type="Area3D" parent="."]
script = ExtResource("lore_rune_script")
position = Vector3(0, 0.4, 6)
rune_id = &"the_seventh_unspoken"
lore_title = "The Seventh, and Unspoken"
lore_body = "The temple teaches six breathings. The first masters knew of a seventh. They did not teach it because they did not need to: the one who learns the six finds the seventh on his own. The wind teaches it. The sun teaches it. Walking does. Listening does."
