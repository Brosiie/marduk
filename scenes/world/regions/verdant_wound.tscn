[node name="LoreRune_the_first_drop" type="Area3D" parent="."]
script = ExtResource("lore_rune_script")
position = Vector3(0, 0.4, -22)
rune_id = &"the_first_drop"
lore_title = "The First Drop"
lore_body = "Tiamat bled here first. Marduk's arrow caught her along the side as she was already turning to leave. The blood ran. The trees took it up. The trees here remember. They are not enemies. They are not allies. They are wrong, and they know it."

[node name="LoreRune_the_wound_keepers" type="Area3D" parent="."]
script = ExtResource("lore_rune_script")
position = Vector3(18, 0.4, 14)
rune_id = &"the_wound_keepers"
lore_title = "The Wound-Keepers"
lore_body = "The druids who tend the Verdant Wound are not gardeners. They are the wound's stewards. They feed it nothing, they water it nothing, they ask it nothing. They walk the paths and they remember. The wound is patient with them."
