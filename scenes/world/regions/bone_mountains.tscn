; ── Conflict spawner for Crown-vs-Druid. Bone Mountains is the Druid
; territorial buffer; baseline reads as druid-aligned wildlife. SKIRMISH
; adds Crown troops probing the passes; OPEN_WAR adds a Witch-Burner
; (the Inquisition arriving as Crown's hard arm).
[node name="ConflictSpawner_bone" type="Node3D" parent="."]
script = ExtResource("conflict_spawner_script")
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 5, 1, 5)
mob_pool = Array[StringName]([&"corrupted_wolf", &"blood_hunter"])
initial_count = 1
max_concurrent = 2
respawn_seconds = 75.0
conflict_pair_key = &"crown_vs_druid"
pool_skirmish = Array[StringName]([&"usurper_footman"])
pool_open_war = Array[StringName]([&"witch_burner"])
