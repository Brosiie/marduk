[node name="Storyteller" type="CharacterBody3D" parent="." groups=["npc"]]
script = ExtResource("npc_script")
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -4, 0.0, -4)
npc_id = &"peasant_male"
display_name = "The Storyteller"
has_quest = true
quest_id = &"q_storyteller_intro"
greeting = "Ah, another champion. Sit. Drink. Listen. The world is breaking and you walked into the middle of it. Want to know how it started?"

[node name="Iddinu" type="CharacterBody3D" parent="." groups=["npc"]]
script = ExtResource("npc_script")
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 4, 0.0, -4)
npc_id = &"peasant_male"
display_name = "Iddinu, Quartermaster"
has_quest = true
quest_id = &"q_iddinu_supplies"
greeting = "We need supplies. Iron. Bread. Anyone with a sword and the time. You qualify on the second count, at least. Three crates. Iron Crown loyalists hold them. Bring them back."

[node name="Belitu" type="CharacterBody3D" parent="." groups=["npc"]]
script = ExtResource("npc_script")
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 0.0, 4)
npc_id = &"peasant_female"
display_name = "Belitu, Market Girl"
has_quest = true
quest_id = &"q_belitu_brother"
greeting = "Have you seen my brother? He went into the Cradle two days ago and hasn't come back. He's only twelve. I can pay you. Not much, but everything I have."


[node name="LoreRune_ashurim_founding" type="Area3D" parent="."]
script = ExtResource("lore_rune_script")
position = Vector3(20, 0.4, 12)
rune_id = &"ashurim_founding"
lore_title = "Ashurim, Founding"
lore_body = "The Storyteller named the city. She has named six cities. Three are still standing. Ashurim is the youngest and the third-best fortified. The other two stood because of their position; Ashurim stands because the Storyteller asked it to."

[node name="LoreRune_the_singing_goat" type="Area3D" parent="."]
script = ExtResource("lore_rune_script")
position = Vector3(-15, 0.4, 8)
rune_id = &"the_singing_goat"
lore_title = "The Singing Goat"
lore_body = "Belitu's inn took its name from a goat that wandered in during the founding and refused to leave. The goat ate every paper in the kitchen and walked out singing. Belitu has been here for forty-one years. The goat has not returned. She is hoping."
