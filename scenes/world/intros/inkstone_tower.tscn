; Inkstone Tower — Mage intro arena.
; Top floor of the Inkstone Sanctum. A circular library room with bookshelves
; lining the walls and a central glyph-floor where the Tower Warden is bound.
; Candles float at chest height, slow-orbiting. Violet sigil-light pulses up
; through the floor cracks. The room feels HUNG with magic.

[sub_resource type="PlaneMesh" id="floor_mesh"]
size = Vector2(60, 60)

[sub_resource type="ShaderMaterial" id="floor_mat"]
shader = ExtResource("4_toon")
shader_parameter/albedo = Color(0.16, 0.13, 0.20, 1)
shader_parameter/bands = 3.0
shader_parameter/ambient = 0.35
shader_parameter/rim_strength = 0.30
shader_parameter/rim_power = 4.5
shader_parameter/rim_color = Color(0.65, 0.50, 0.95, 1)
shader_parameter/shadow_tint = Color(0.08, 0.06, 0.12, 1)

[sub_resource type="BoxShape3D" id="floor_shape"]
size = Vector3(60, 0.4, 60)

[sub_resource type="StandardMaterial3D" id="shelf_mat"]
albedo_color = Color(0.30, 0.22, 0.18, 1)
roughness = 0.92

[sub_resource type="BoxShape3D" id="shelf_shape"]
size = Vector3(2.4, 4.5, 0.6)

[sub_resource type="BoxMesh" id="shelf_mesh"]
size = Vector3(2.4, 4.5, 0.6)

[sub_resource type="ProceduralSkyMaterial" id="sky_mat"]
sky_top_color = Color(0.06, 0.04, 0.10, 1)
sky_horizon_color = Color(0.20, 0.10, 0.30, 1)
ground_horizon_color = Color(0.10, 0.06, 0.15, 1)
ground_bottom_color = Color(0.04, 0.03, 0.06, 1)

[sub_resource type="Sky" id="sky"]
sky_material = SubResource("sky_mat")

[sub_resource type="Environment" id="env"]
background_mode = 2
sky = SubResource("sky")
ambient_light_source = 2
ambient_light_color = Color(0.65, 0.55, 0.95, 1)
ambient_light_energy = 0.55
fog_enabled = true
fog_density = 0.022
fog_light_color = Color(0.55, 0.40, 0.95, 1)

[sub_resource type="CapsuleShape3D" id="player_shape"]
radius = 0.4
height = 1.7

; ── Upper mezzanine balcony + spiral stair geometry ─────────────
; Tower felt like a flat library room, not a tower. Add a U-shaped
; mezzanine ringing the back half at y=5.5 and a 12-step spiral stair
; on the east side that climbs from ground (y=0) to the mezzanine.
; Each step is 0.45m tall, 1.2m wide, 0.6m deep.
[sub_resource type="StandardMaterial3D" id="upper_mat"]
albedo_color = Color(0.22, 0.18, 0.26, 1)
roughness = 0.85

[sub_resource type="BoxMesh" id="balcony_mesh"]
size = Vector3(38, 0.4, 8)

[sub_resource type="BoxShape3D" id="balcony_shape"]
size = Vector3(38, 0.4, 8)

[sub_resource type="BoxMesh" id="rail_mesh"]
size = Vector3(38, 1.0, 0.2)

[sub_resource type="BoxShape3D" id="rail_shape"]
size = Vector3(38, 1.0, 0.2)

[sub_resource type="BoxMesh" id="step_mesh"]
size = Vector3(1.2, 0.45, 0.6)

[sub_resource type="BoxShape3D" id="step_shape"]
size = Vector3(1.2, 0.45, 0.6)

