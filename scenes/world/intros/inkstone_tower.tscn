; Inkstone Tower — Mage intro arena.
; Top floor of the Inkstone Sanctum. A circular library room with bookshelves
; lining the walls and a central glyph-floor where the Tower Warden is bound.
; Candles float at chest height, slow-orbiting. Violet sigil-light pulses up
; through the floor cracks. The room feels HUNG with magic.

[sub_resource type="PlaneMesh" id="floor_mesh"]
size = Vector2(60, 60)

[sub_resource type="ShaderMaterial" id="floor_mat"]
shader = ExtResource("4_toon")
shader_parameter/albedo = Color(0.16, 0.13, 0.20, 1)
shader_parameter/bands = 3.0
shader_parameter/ambient = 0.35
shader_parameter/rim_strength = 0.30
shader_parameter/rim_power = 4.5
shader_parameter/rim_color = Color(0.65, 0.50, 0.95, 1)
shader_parameter/shadow_tint = Color(0.08, 0.06, 0.12, 1)

[sub_resource type="BoxShape3D" id="floor_shape"]
size = Vector3(60, 0.4, 60)

[sub_resource type="StandardMaterial3D" id="shelf_mat"]
albedo_color = Color(0.30, 0.22, 0.18, 1)
roughness = 0.92

[sub_resource type="BoxShape3D" id="shelf_shape"]
size = Vector3(2.4, 4.5, 0.6)

[sub_resource type="BoxMesh" id="shelf_mesh"]
size = Vector3(2.4, 4.5, 0.6)

[sub_resource type="ProceduralSkyMaterial" id="sky_mat"]
