ground_horizon_color = Color(0.10, 0.06, 0.15, 1)
ground_bottom_color = Color(0.04, 0.03, 0.06, 1)

[sub_resource type="Sky" id="sky"]
sky_material = SubResource("sky_mat")

[sub_resource type="Environment" id="env"]
background_mode = 2
sky = SubResource("sky")
ambient_light_source = 2
ambient_light_color = Color(0.65, 0.55, 0.95, 1)
ambient_light_energy = 0.55
fog_enabled = true
fog_density = 0.022
fog_light_color = Color(0.55, 0.40, 0.95, 1)

