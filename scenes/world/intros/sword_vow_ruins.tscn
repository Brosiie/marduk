[node name="Geometry" type="Node3D" parent="."]
script = ExtResource("zone_composer")
style_id = &"sword_vow_ruins"
; Was 80.0 (half-extent 40). Player spawns at z=70 ("FAR SOUTH campfire at
; spawn marker" per the layout doc), which sat 30m outside the prop zone.
; Bond's "no terrain or trees" complaint was literal: he spawned in the void
; south of the generated grove. Size 160 covers spawn-to-boss (z range -80
; to +80) while staying inside the 180m floor.
size = 160.0


[node name="LoreRune_kazats_oath" type="Area3D" parent="."]
script = ExtResource("lore_rune_script")
position = Vector3(15, 0.4, -10)
rune_id = &"kazats_oath"
lore_title = "The Oath of Kazat"
lore_body = "Enforcer Kazat took the iron mask Tashmu offered him an hour after Lord Ennum died. He keeps the mask polished. The oath he took before the Sword-Vow he no longer remembers, and the men who heard him take it are all dead. He polishes the mask twice a day."

[node name="LoreRune_ennums_last_word" type="Area3D" parent="."]
script = ExtResource("lore_rune_script")
position = Vector3(-12, 0.4, -5)
rune_id = &"ennums_last_word"
lore_title = "Ennum's Last Word"
lore_body = "Lord Ennum said \"sword\" before Tashmu's blade took his throat. The court chroniclers wrote it down as a vow renewal. The Storyteller, who was there, writes it as a question. She has not corrected the chronicle. She will not."
