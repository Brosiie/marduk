ground_horizon_color = Color(0.40, 0.20, 0.12, 1)
ground_bottom_color = Color(0.10, 0.06, 0.04, 1)

[sub_resource type="Sky" id="sky"]
sky_material = SubResource("sky_mat")

[sub_resource type="Environment" id="env"]
background_mode = 2
sky = SubResource("sky")
ambient_light_source = 2
