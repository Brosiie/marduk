; Ash-Step Camp — Berserker intro arena.
; Volcanic ash plain east of the Bone Mountains. Broken pillar to one side
; (Hassu uses it for his Pillar-Vault). Raid-camp ash-pit nearby. Sky reads
; pre-dawn red. Hassu the Hooked waits in the center.
;
; Phase-2 polish later: mob waves of steppe-clansmen between player and Hassu;
; ash-particle ambient; broken-pillar physics for impact-burst on Pillar-Vault.

[sub_resource type="PlaneMesh" id="floor_mesh"]
size = Vector2(120, 120)

[sub_resource type="ShaderMaterial" id="floor_mat"]
shader = ExtResource("4_toon")
shader_parameter/albedo = Color(0.22, 0.18, 0.16, 1)
shader_parameter/bands = 3.0
shader_parameter/ambient = 0.28
shader_parameter/rim_strength = 0.25
shader_parameter/rim_power = 4.5
shader_parameter/rim_color = Color(0.95, 0.45, 0.20, 1)
shader_parameter/shadow_tint = Color(0.10, 0.07, 0.05, 1)

[sub_resource type="BoxShape3D" id="floor_shape"]
size = Vector3(120, 0.4, 120)

[sub_resource type="StandardMaterial3D" id="pillar_mat"]
albedo_color = Color(0.40, 0.32, 0.28, 1)
roughness = 0.90

[sub_resource type="CylinderShape3D" id="pillar_shape"]
