; Coven Glen — Chaos Druid intro arena.
; Wound-corrupted clearing in the Verdant Wound. Bog-soft floor with
; sickly-violet vine patches. Broken stone-circle remnants from the old
; Druid coven (the Inquisition burned through here a generation ago).
; Sahirum the Witch-Burner waits at the largest broken stone, torch lit.
; The Wound has not forgotten.

[sub_resource type="PlaneMesh" id="floor_mesh"]
size = Vector2(100, 100)

[sub_resource type="ShaderMaterial" id="floor_mat"]
shader = ExtResource("4_toon")
shader_parameter/albedo = Color(0.18, 0.22, 0.16, 1)
shader_parameter/bands = 3.0
shader_parameter/ambient = 0.30
shader_parameter/rim_strength = 0.25
shader_parameter/rim_power = 4.5
