{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Marduk Launcher",
  "version": "0.1.0",
  "identifier": "game.marduk.launcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Marduk",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' https://marduk.game data:; connect-src 'self' https://api.marduk.game https://marduk.game"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Game",
    "shortDescription": "Marduk - Babylonian fantasy ARPG",
    "longDescription": "Free, open-source Babylonian fantasy ARPG. Champion of Marduk versus Tiamat and her spawn."
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": ["https://marduk.game/launcher/update.json"],
      "pubkey": "REPLACE_WITH_PUBLIC_KEY"
    }
  }
}
