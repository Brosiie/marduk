; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Marduk"
config/description="ARPG dungeon crawler. Marduk vs Tiamat."
run/main_scene="res://scenes/world/intros/sword_vow_ruins.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
boot_splash/bg_color=Color(0.04, 0.024, 0.047, 1)
boot_splash/stretch_mode=0
boot_splash/image="res://boot_splash.png"
config/icon="res://icon.svg"

[autoload]

CombatBus="*res://scripts/combat/combat_bus.gd"
AppearanceRegistry="*res://scripts/player/appearance_registry.gd"
