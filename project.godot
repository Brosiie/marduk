; Marduk
; Babylonian fantasy ARPG. Champion of Marduk versus Tiamat and her spawn.
; Engine: Godot 4.6. Renderer: Forward+ for stylized lighting.

config_version=5

[application]

config/name="Marduk"
config/description="ARPG dungeon crawler. Marduk vs Tiamat."
config/features=PackedStringArray("4.6", "Forward Plus")
run/main_scene="res://scenes/main.tscn"
config/icon="res://icon.svg"

[autoload]

; Load order matters. Top-down dependency:
;   SaveFlags                   - foundational, no deps
;   Prestige                    - uses SaveFlags
;   AudioBus                    - independent
;   SaveSystem                  - uses SaveFlags + Prestige + ClassRegistry (lazy access)
;   BreathingRegistry           - uses SaveFlags
;   WorldMap                    - uses SaveFlags
;   LegendaryRegistry           - uses Item resource
;   ItemRegistry                - 130+ items, independent
;   ClassProficiencyRegistry    - independent, queried by damage_calc
;   BossRegistry                - independent
;   AuctionHouse                - independent runtime
;   ClassRegistry               - LAST (depends on BreathingRegistry via SkillTreeFactory)
SaveFlags="*res://scripts/save_flags.gd"
Prestige="*res://scripts/prestige.gd"
WorldClock="*res://scripts/world/world_clock.gd"
GameSettings="*res://scripts/settings/game_settings.gd"
KeyBindings="*res://scripts/input/key_bindings.gd"
AuthClient="*res://scripts/auth/auth_client.gd"
RealtimeChannel="*res://scripts/network/realtime_channel.gd"
Social="*res://scripts/social/social.gd"
PartyManager="*res://scripts/social/party_manager.gd"
WorldManager="*res://scripts/world/world_manager.gd"
MountRegistry="*res://scripts/mounts/mount_registry.gd"
PetRegistry="*res://scripts/pets/pet_registry.gd"
AudioBus="*res://scripts/audio/audio_bus.gd"
SaveSystem="*res://scripts/save/save_system.gd"
BreathingRegistry="*res://scripts/skills/breathing_registry.gd"
MageSpellRegistry="*res://scripts/skills/mage_spell_registry.gd"
WorldMap="*res://scripts/world/world_map.gd"
LegendaryRegistry="*res://scripts/items/legendary_registry.gd"
ItemRegistry="*res://scripts/items/item_registry.gd"
ClassProficiencyRegistry="*res://scripts/items/class_proficiency_registry.gd"
BossRegistry="*res://scripts/enemies/boss_registry.gd"
MobRegistry="*res://scripts/mobs/mob_registry.gd"
DungeonRegistry="*res://scripts/dungeon/dungeon_registry.gd"
LandmarkRegistry="*res://scripts/landmarks/landmark_registry.gd"
QuestRegistry="*res://scripts/quests/quest_registry.gd"
DialogueRegistry="*res://scripts/quests/dialogue_registry.gd"
TitleRegistry="*res://scripts/titles/title_registry.gd"
AchievementRegistry="*res://scripts/achievements/achievement_registry.gd"
AuctionHouse="*res://scripts/economy/auction_house.gd"
ShopkeeperRegistry="*res://scripts/economy/shopkeeper_registry.gd"
ClassRegistry="*res://scripts/classes/class_registry.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"

