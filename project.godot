MageSpellRegistry="*res://scripts/skills/mage_spell_registry.gd"
WorldMap="*res://scripts/world/world_map.gd"
LegendaryRegistry="*res://scripts/items/legendary_registry.gd"
ItemRegistry="*res://scripts/items/item_registry.gd"
IconAtlas="*res://scripts/items/icon_atlas.gd"
LootGenerator="*res://scripts/items/loot_generator.gd"
ClassProficiencyRegistry="*res://scripts/items/class_proficiency_registry.gd"
ClassMeshRegistry="*res://scripts/classes/class_mesh_registry.gd"
AnimationRegistry="*res://scripts/anim/animation_registry.gd"
BossRegistry="*res://scripts/enemies/boss_registry.gd"
MobRegistry="*res://scripts/mobs/mob_registry.gd"
DungeonRegistry="*res://scripts/dungeon/dungeon_registry.gd"
LandmarkRegistry="*res://scripts/landmarks/landmark_registry.gd"
QuestRegistry="*res://scripts/quests/quest_registry.gd"
DialogueRegistry="*res://scripts/quests/dialogue_registry.gd"
TitleRegistry="*res://scripts/titles/title_registry.gd"
AchievementRegistry="*res://scripts/achievements/achievement_registry.gd"
CodexRegistry="*res://scripts/lore/codex_registry.gd"
CodexSeed="*res://scripts/lore/codex_seed.gd"
AuctionHouse="*res://scripts/economy/auction_house.gd"
ShopkeeperRegistry="*res://scripts/economy/shopkeeper_registry.gd"
FactionRegistry="*res://scripts/factions/faction_registry.gd"
TiamatRegistry="*res://scripts/world/tiamat_registry.gd"
WoundRegistry="*res://scripts/world/wound_registry.gd"
ClassRegistry="*res://scripts/classes/class_registry.gd"
PlaytestBot="*res://scripts/test/playtest_bot.gd"

[debug]

gdscript/warnings/unused_variable=0
gdscript/warnings/unused_parameter=0
gdscript/warnings/shadowed_variable=0
gdscript/warnings/shadowed_variable_base_class=0
gdscript/warnings/standalone_expression=0
gdscript/warnings/redundant_await=0
gdscript/warnings/native_method_override=0
gdscript/warnings/treat_warnings_as_errors=false

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"

