{
  "name": "marduk-api",
  "version": "0.1.0",
  "description": "Cloudflare Worker backend for Marduk ARPG",
  "license": "MIT",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:init": "wrangler d1 execute marduk --file=migrations/0001_init.sql",
    "db:console": "wrangler d1 execute marduk --command \"SELECT name FROM sqlite_master WHERE type='table';\"",
    "test": "vitest"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250101.0",
    "wrangler": "^3.99.0",
    "typescript": "^5.5.0",
    "vitest": "^1.5.0"
  },
  "dependencies": {
    "hono": "^4.6.0",
    "@phc/argon2": "^1.0.0",
    "@tsndr/cloudflare-worker-jwt": "^3.0.0"
  }
}
